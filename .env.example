# App
# PostgreSQL (bundled docker postgres defaults)
POSTGRES_HOST="postgres"
POSTGRES_PORT="5432"
POSTGRES_DB="pickrr"
POSTGRES_USER="pickrr"
POSTGRES_PASSWORD="pickrr"
# Optional: set this to use external/managed Postgres.
# If empty, Pickrr auto-builds DATABASE_URL from POSTGRES_* and uses bundled postgres service.
DATABASE_URL=""
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
ADMIN_PASSWORD="changeme"

# Prowlarr
PROWLARR_URL="http://prowlarr:9696"
PROWLARR_API_KEY=""

# qBittorrent
QBIT_URL="http://gluetun:8080"
QBIT_USERNAME="admin"
QBIT_PASSWORD=""

# TMDB
TMDB_API_KEY=""

# Jellyfin (optional, for Jellyfin login)
JELLYFIN_URL="http://jellyfin:8096"

# Save Paths
MOVIES_SAVE_PATH="/downloads/movies"
TV_SAVE_PATH="/downloads/tv"
