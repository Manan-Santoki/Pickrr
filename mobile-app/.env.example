# Application environment: development | preview | production
EXPO_PUBLIC_APP_ENV=development

# Pickrr backend API (must be reachable by iOS/Android client)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Optional associated domain for universal links
# EXPO_PUBLIC_ASSOCIATED_DOMAIN=https://pickrr.app

# Optional MMKV encryption key for local secure storage
EXPO_PUBLIC_MMKV_ENCRYPTION_KEY=replace-with-strong-random-string

# Required by env schema
EXPO_PUBLIC_VAR_NUMBER=10
EXPO_PUBLIC_VAR_BOOL=true

# Build-time only (not exposed to JS runtime)
APP_BUILD_ONLY_VAR=build-only-value
